DATABASE_URL=sqlite:///./stocky.db
JWT_SECRET=change-me-in-production-use-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080
INITIAL_MOCK_CASH=100000
CORS_ORIGINS=http://localhost:5173

# Reddit API (script app from https://www.reddit.com/prefs/apps)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=stocky-local/0.1 by u/your_username

# Finnhub free tier (https://finnhub.io/register) — enables the insider signal
FINNHUB_API_KEY=

# Admin endpoints lock (when set, /api/admin/* requires X-Admin-Token header)
ADMIN_TOKEN=
